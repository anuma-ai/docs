{
  "name": "ai-docs",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "dev": "next",
    "prebuild": "node scripts/generate-static.mjs",
    "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
    "start": "next start",
    "ingest": "tsx scripts/ingest-docs.ts",
    "update:docs": "./scripts/update-docs.sh",
    "build:cloudflare": "pnpm build && opennextjs-cloudflare build",
    "preview:cloudflare": "pnpm build:cloudflare && opennextjs-cloudflare preview",
    "deploy:cloudflare": "pnpm build:cloudflare && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@anuma/portal": "1.0.0-next.20260224221541",
    "@anuma/sdk": "1.0.0-next.20260317085051",
    "@opennextjs/cloudflare": "^1.17.1",
    "@scalar/api-reference-react": "^0.8.15",
    "@theguild/remark-mermaid": "^0.3.0",
    "next": "^16.1.7",
    "next-themes": "^0.4.6",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "pagefind": "^1.3.0",
    "tsx": "^4.21.0",
    "wrangler": "^4.68.1"
  }
}